---
const links = [
  { label: 'Home', href: '/' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Contact', href: '/contact' },
];

// current path, without a trailing slash, so /portfolio/ and /portfolio both match
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="ps2-header">
  <div class="ps2-wrap ps2-header__inner">
    <a class="ps2-header__logo" href="/">PromoStrats<span>.</span></a>

    <button class="ps2-header__toggle" aria-expanded="false" aria-controls="ps2-nav">
      <span class="ps2-header__toggle-bars"></span>
      <span class="ps2-visually-hidden">Menu</span>
    </button>

    <nav class="ps2-header__nav" id="ps2-nav">
      <ul>
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={path === link.href.replace(/\/$/, '') || (link.href === '/' && path === '/') ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
      <a class="ps2-btn ps2-header__cta" href="/contact">Book a call</a>
    </nav>
  </div>
</header>

<style>
  .ps2-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(250, 250, 246, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--ps2-line);
  }

  .ps2-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 60px;
  }

  .ps2-header__logo {
    font-family: var(--ps2-disp);
    font-weight: 800;
    font-size: 21px;
    letter-spacing: -0.02em;
    color: var(--ps2-ink);
    text-decoration: none;
  }

  .ps2-header__logo span {
    color: var(--ps2-cobalt);
  }

  .ps2-header__nav {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .ps2-header__nav ul {
    display: flex;
    align-items: center;
    gap: 28px;
    list-style: none;
  }

  .ps2-header__nav a {
    font-size: 15px;
    font-weight: 500;
    color: var(--ps2-ink-soft);
    text-decoration: none;
    position: relative;
    padding-bottom: 4px;
    transition: color 0.15s ease;
  }

  /* the nav underline that grows from the centre */
  .ps2-header__nav ul a::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 0;
    width: 0;
    height: 1px;
    background: currentColor;
    transform: translateX(-50%);
    transition: width 0.25s ease;
  }

  .ps2-header__nav ul a:hover {
    color: var(--ps2-ink);
  }

  .ps2-header__nav ul a:hover::after {
    width: 100%;
  }

  .ps2-header__nav ul a[aria-current='page'] {
    color: var(--ps2-cobalt);
  }

  .ps2-header__cta {
    color: #fff;
    padding: 9px 18px;
    font-size: 14px;
    background: var(--ps2-green);
}
.ps2-header__cta {
    position: relative;
    top: -2px;
    right: 4px;
  }
.ps2-header__cta:hover {
    background: var(--ps2-green);
  }

  .ps2-header__cta::after {
    display: none;
  }

  /* mobile toggle */
  .ps2-header__toggle {
    display: none;
    width: 44px;
    height: 44px;
    background: none;
    border: 0;
    cursor: pointer;
    align-items: center;
    justify-content: center;
  }

  .ps2-header__toggle-bars,
  .ps2-header__toggle-bars::before,
  .ps2-header__toggle-bars::after {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--ps2-ink);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .ps2-header__toggle-bars::before,
  .ps2-header__toggle-bars::after {
    content: '';
    position: absolute;
  }

  .ps2-header__toggle-bars::before {
    transform: translateY(-6px);
  }

  .ps2-header__toggle-bars::after {
    transform: translateY(6px);
  }

  .ps2-header__toggle[aria-expanded='true'] .ps2-header__toggle-bars {
    background: transparent;
  }

  .ps2-header__toggle[aria-expanded='true'] .ps2-header__toggle-bars::before {
    transform: rotate(45deg);
  }

  .ps2-header__toggle[aria-expanded='true'] .ps2-header__toggle-bars::after {
    transform: rotate(-45deg);
  }

  .ps2-visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  @media (max-width: 760px) {
    .ps2-header__toggle {
      display: flex;
    }

    .ps2-header__nav {
      display: none;
      position: absolute;
      left: 0;
      right: 0;
      top: 100%;
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
      padding: 20px;
      background: var(--ps2-paper);
      border-bottom: 1px solid var(--ps2-line);
    }

    .ps2-header__nav[data-open='true'] {
      display: flex;
    }

    .ps2-header__nav ul {
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
      width: 100%;
    }

    .ps2-header__nav ul a {
      display: block;
      padding: 10px 0;
      font-size: 17px;
    }

    .ps2-header__cta {
      margin-top: 12px;
    }
  }
</style>

<script>
  const toggle = document.querySelector('.ps2-header__toggle');
  const nav = document.getElementById('ps2-nav');

  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    nav?.setAttribute('data-open', String(!open));
  });
</script>
