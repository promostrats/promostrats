---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const {
  title = 'PromoStrats — Shopify design & SEO for UK independent brands',
  description = "Freelance Shopify design and SEO in London. I find the structure, usability and SEO issues quietly costing you sales — then fix them properly, inside your existing theme.",
  image = '/og-image.png',
  noindex = false,
} = Astro.props;

// Astro.site comes from astro.config.mjs. Social platforms and search engines
// ignore relative image paths, so these have to be absolute URLs.
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'PromoStrats',
  description: 'Shopify design and SEO for UK independent brands.',
  url: 'https://promostrats.com',
  email: 'promostrats@gmail.com',
  telephone: '+447514043068',
  founder: { '@type': 'Person', name: 'Connor Bawcutt' },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'London',
    addressRegion: 'East Dulwich',
    addressCountry: 'GB',
  },
  areaServed: { '@type': 'Country', name: 'United Kingdom' },
  knowsAbout: ['Shopify', 'Shopify theme development', 'Ecommerce SEO', 'Liquid', 'Web design'],
  sameAs: [
    'https://www.linkedin.com/in/connor-bawcutt-865972269/',
    'https://www.facebook.com/profile.php?id=61576358156844',
  ],
};
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- open graph — facebook, linkedin, whatsapp, slack -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="PromoStrats" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_GB" />

    <!-- twitter / x -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <!-- fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <a class="ps2-skip" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <div id="scroll-progress"><div id="scroll-progress__bar"></div></div>

    <style is:global>
      .ps2-skip {
        position: absolute;
        left: -9999px;
      }

      .ps2-skip:focus {
        left: 16px;
        top: 16px;
        z-index: 100;
        background: #fff;
        padding: 10px 16px;
        border-radius: 6px;
      }

      #scroll-progress {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 3px;
        z-index: 9999;
        pointer-events: none;
        background: transparent;
      }

      #scroll-progress__bar {
        height: 100%;
        width: 0%;
        background: var(--ps2-cobalt);
        transform-origin: left center;
        transition: width 0.08s linear;
      }
    </style>

    <script>
      const bar = document.getElementById('scroll-progress__bar');
      const update = () => {
        const h = document.documentElement.scrollHeight - window.innerHeight;
        const pct = h > 0 ? (window.scrollY / h) * 100 : 0;
        if (bar) bar.style.width = pct + '%';
      };
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);
      update();
    </script>
  </body>
</html>