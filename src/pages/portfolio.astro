---
import Layout from '../layouts/Layout.astro';

// Drop your screenshots into public/images/ and the paths below will just work.
// Leave a value as null and you'll get the striped placeholder instead.
const cases = [
  {
    number: '01',
    scope: 'redesign · seo · ongoing',
    name: 'The Artisan Merchants',
    desc: 'A tired default theme rebuilt into a proper curated-goods storefront.',
    live: 'https://theartisanmerchants.co.uk',
    compares: [
      {
        label: 'homepage.compare',
        before: '/images/tam-home-before.png',
        after: '/images/tam-home-after.png',
        alt: 'The Artisan Merchants homepage',
      },
      {
        label: 'collection-page.compare',
        before: '/images/tam-collection-before.png',
        after: '/images/tam-collection-after.png',
        alt: 'The Artisan Merchants collection page',
      },
    ],
    copy: `The Artisan Merchants sell hand-crafted European toys and decorations, but the site looked like every other stock Shopify shop — a generic slider, flat collection tiles and no real identity. I rebuilt the homepage and collection pages around a <strong>"curator's cabinet" look</strong>: deep navy, brass detailing and an editorial layout that makes the products feel collected rather than just listed. The collection pages got <strong>working sidebar filters</strong> for maker, type and price. Earlier on I also sorted their search-engine setup and product copy, and I look after the site on an ongoing basis.`,
    changelog: [
      { type: 'del', text: 'generic stock theme, no identity' },
      { type: 'add', text: "curator's cabinet redesign" },
      { type: 'add', text: 'collection sidebar filters' },
      { type: 'add', text: 'editorial product cards' },
      { type: 'add', text: 'seo setup + product copy' },
      { type: 'add', text: 'ongoing support' },
    ],
  },
  {
    number: '02',
    scope: 'homepage redesign',
    name: 'Flavour Like Fancy',
    desc: 'A plain theme rebuilt to match the personality of a colourful Leeds gift shop.',
    live: 'https://flavourlikefancy.co.uk',
    compares: [
      {
        label: 'homepage.compare',
        before: '/images/flf-before.png',
        after: '/images/flf-after.png',
        alt: 'Flavour Like Fancy homepage',
      },
    ],
    copy: `Flavour Like Fancy is a bright, independent gift shop in Chapel Allerton, Leeds — but online it was running a stock theme that gave none of that personality away. I redesigned the homepage to match how the shop actually feels: a <strong>bold hero with a hand-cut product collage</strong>, a colourful scrolling banner, a clear <strong>"shop by collection" grid</strong>, and dedicated sections for their craft workshops and their physical shop. It looks like the brand now instead of a template, and points visitors straight to what they came for.`,
    changelog: [
      { type: 'del', text: 'stock theme, zero personality' },
      { type: 'add', text: 'hand-cut hero collage' },
      { type: 'add', text: 'shop-by-collection grid' },
      { type: 'add', text: 'workshops section' },
      { type: 'add', text: 'store + map section' },
    ],
  },
];
---

<Layout title="Portfolio — PromoStrats" description="Real websites designed, built and optimised for UK independent brands, with a specialism in Shopify. Drag any comparison to see exactly what changed.">
  <section class="ps2p">
    <!-- header -->
    <div class="ps2-wrap">
      <header class="ps2p-head">
        <span class="ps2-eyebrow">// portfolio — real client work</span>
        <h1>Before, <em>and after</em>.</h1>
        <p class="ps2p-lede">
          Real websites I've designed, built and optimised for UK independent brands — Shopify is my specialism. Drag
          across any comparison to see exactly what changed.
        </p>
        <p class="ps2p-head-meta">
          <b>{cases.length} case studies</b> &middot; web design &middot; development &middot; seo
        </p>
      </header>
    </div>

    <!-- cases -->
    <div class="ps2-wrap">
      {
        cases.map((c) => (
          <article class="ps2p-case">
            <div class="ps2p-case-head">
              <span class="ps2-eyebrow">// case {c.number}</span>
              <span class="ps2p-case-scope">{c.scope}</span>
              <h2 class="ps2p-case-name">{c.name}</h2>
              <p class="ps2p-case-desc">{c.desc}</p>
            </div>

            {c.compares.map((cmp) => (
              <div class="ps2p-compare">
                <div class="ps2p-panel">
                  <div class="ps2p-panel-head">
                    <span>{cmp.label}</span>
                    <span class="ps2p-drag-hint">drag to compare &#8646;</span>
                  </div>
                  <div class="ps2p-panel-body">
                    <div class="ps2p-ba" data-ba>
                      <input
                        class="ps2p-ba-range"
                        type="range"
                        min="0"
                        max="100"
                        value="50"
                        aria-label={`Drag to reveal ${cmp.alt} before and after`}
                      />
                      <div class="ps2p-ba-frame">
                        <figure class="ps2p-ba-layer ps2p-ba-layer--after">
                          {cmp.after ? (
                            <img src={cmp.after} alt={`${cmp.alt} — redesigned`} loading="lazy" decoding="async" />
                          ) : (
                            <div class="ps2p-ba-ph">+ after &mdash; add image to public/images</div>
                          )}
                          <figcaption class="ps2p-ba-tag ps2p-ba-tag--after">+ after</figcaption>
                        </figure>
                        <figure class="ps2p-ba-layer ps2p-ba-layer--before">
                          {cmp.before ? (
                            <img src={cmp.before} alt={`${cmp.alt} — original`} loading="lazy" decoding="async" />
                          ) : (
                            <div class="ps2p-ba-ph">- before &mdash; add image to public/images</div>
                          )}
                          <figcaption class="ps2p-ba-tag ps2p-ba-tag--before">- before</figcaption>
                        </figure>
                        <div class="ps2p-ba-divider">
                          <span class="ps2p-ba-grip" />
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            ))}

            <div class="ps2p-body">
              <p class="ps2p-copy" set:html={c.copy} />
              <div class="ps2p-side">
                <div class="ps2p-changelog">
                  <div class="ps2p-changelog-title">// changelog</div>
                  {c.changelog.map((l) =>
                    l.type === 'del' ? (
                      <div class="ps2p-cl-line ps2p-cl-line--del">
                        <span class="ps2p-cl-mark">-</span>
                        <s>{l.text}</s>
                      </div>
                    ) : (
                      <div class="ps2p-cl-line ps2p-cl-line--add">
                        <span class="ps2p-cl-mark">+</span>
                        {l.text}
                      </div>
                    )
                  )}
                </div>
                <a class="ps2p-live" href={c.live} target="_blank" rel="noopener">
                  View live site <span>&nearr;</span>
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <!-- cta -->
    <div class="ps2p-cta">
      <div class="ps2-wrap">
        <span class="ps2-eyebrow">// next step</span>
        <h2>Want your site to look like the "after"?</h2>
        <p>
          I'll review your current site before we talk — or scope a new build from scratch — and walk you through
          exactly what I'd do: structure, usability and SEO.
        </p>
        <a class="ps2p-cta-btn" href="/contact">Book your free strategy call</a>
        <div class="ps2p-cta-note">free 20-min call &middot; you keep the advice either way</div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .ps2p img {
    display: block;
    max-width: 100%;
  }

  /* ---------- header ---------- */
  .ps2p-head {
    padding: 84px 0 64px;
    border-bottom: 1px solid var(--ps2-line);
  }

  .ps2p-head h1 {
    font-family: var(--ps2-disp);
    font-weight: 800;
    letter-spacing: -0.03em;
    font-size: clamp(40px, 5.4vw, 62px);
    line-height: 1.02;
    margin-top: 22px;
  }

  .ps2p-head h1 em {
    font-style: normal;
    color: var(--ps2-cobalt);
  }

  .ps2p-lede {
    margin-top: 24px;
    font-size: 19px;
    color: var(--ps2-ink-soft);
    max-width: 48ch;
  }

  .ps2p-head-meta {
    margin-top: 28px;
    font-family: var(--ps2-mono);
    font-size: 12.5px;
    color: var(--ps2-ink-soft);
  }

  .ps2p-head-meta b {
    color: var(--ps2-ink);
    font-weight: 500;
  }

  /* ---------- case ---------- */
  .ps2p-case {
    padding: 88px 0;
  }

  .ps2p-case + .ps2p-case {
    border-top: 1px solid var(--ps2-line);
  }

  .ps2p-case-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 10px 20px;
    margin-bottom: 8px;
  }

  .ps2p-case-scope {
    margin-left: auto;
    font-family: var(--ps2-mono);
    font-size: 12.5px;
    color: var(--ps2-ink-soft);
  }

  .ps2p-case-name {
    font-family: var(--ps2-disp);
    font-weight: 700;
    letter-spacing: -0.025em;
    font-size: clamp(30px, 4vw, 44px);
    line-height: 1.06;
    flex-basis: 100%;
    margin-top: 8px;
  }

  .ps2p-case-desc {
    font-size: 18px;
    color: var(--ps2-ink-soft);
    margin-top: 12px;
    max-width: 56ch;
  }

  /* ---------- compare panel ---------- */
  .ps2p-compare {
    margin-top: 40px;
  }

  .ps2p-panel {
    background: var(--ps2-panel);
    border: 1px solid var(--ps2-panel-line);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 24px 60px -24px rgba(21, 23, 27, 0.4);
  }

  .ps2p-panel-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 18px;
    border-bottom: 1px solid var(--ps2-panel-line);
    font-family: var(--ps2-mono);
    font-size: 12.5px;
    color: #7a8291;
  }

  .ps2p-panel-head .ps2p-drag-hint {
    color: var(--ps2-green);
  }

  .ps2p-panel-body {
    padding: 12px;
  }

  /* ---------- before/after slider ---------- */
  .ps2p-ba {
    position: relative;
    touch-action: pan-y;
  }

  .ps2p-ba-frame {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 6px;
    background: #1b1e24;
    --pos: 50%;
    --fw: 100%;
  }

  .ps2p-ba-layer {
    position: absolute;
    inset: 0;
    margin: 0;
  }

  .ps2p-ba-layer img,
  .ps2p-ba-ph {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  .ps2p-ba-layer--before {
    width: var(--pos);
    overflow: hidden;
    border-right: 2px solid var(--ps2-cobalt);
    transition: var(--pos-transition, none);
  }

  .ps2p-ba-layer--before img,
  .ps2p-ba-layer--before .ps2p-ba-ph {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: var(--fw);
    max-width: none;
  }

  .ps2p-ba-ph {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1rem;
    font-family: var(--ps2-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: #7a8291;
    background: repeating-linear-gradient(45deg, #16181d 0 12px, #1b1e24 12px 24px);
  }

  .ps2p-ba-tag {
    position: absolute;
    top: 12px;
    font-family: var(--ps2-mono);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 5px 11px;
    border-radius: 5px;
    background: rgba(16, 18, 22, 0.85);
    backdrop-filter: blur(4px);
  }

  .ps2p-ba-tag--before {
    left: 12px;
    color: #ff9c86;
  }

  .ps2p-ba-tag--after {
    right: 12px;
    color: var(--ps2-green);
  }

  .ps2p-ba-divider {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--pos);
    transform: translateX(-50%);
    width: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    transition: var(--pos-transition, none);
  }

  .ps2p-ba-grip {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #fff;
    border: 2px solid var(--ps2-cobalt);
    box-shadow: 0 4px 18px rgba(21, 23, 27, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ps2p-ba-grip::before {
    content: '\2039 \203A';
    font-family: var(--ps2-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--ps2-cobalt);
    letter-spacing: -1px;
  }

  .ps2p-ba-range {
    -webkit-appearance: none;
    appearance: none;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    background: transparent;
    cursor: ew-resize;
    z-index: 3;
    border: none;
    box-shadow: none;
    outline: none;
  }

  .ps2p-ba-range:focus-visible ~ .ps2p-ba-frame {
    outline: 2px solid var(--ps2-cobalt);
    outline-offset: 3px;
  }

  .ps2p-ba-range::-webkit-slider-runnable-track {
    -webkit-appearance: none;
    appearance: none;
    background: transparent;
    border: none;
    box-shadow: none;
    height: 100%;
  }

  .ps2p-ba-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 44px;
    height: 9999px;
    margin-top: -4000px;
    background: transparent;
    border: none;
    box-shadow: none;
  }

  .ps2p-ba-range::-moz-range-track {
    background: transparent;
    border: none;
  }

  .ps2p-ba-range::-moz-range-thumb {
    width: 44px;
    height: 100%;
    border: 0;
    background: transparent;
    box-shadow: none;
  }

  /* ---------- writeup + changelog ---------- */
  .ps2p-body {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: clamp(28px, 4vw, 56px);
    margin-top: 44px;
    align-items: start;
  }

  .ps2p-copy {
    font-size: 16.5px;
    line-height: 1.75;
    color: var(--ps2-ink-soft);
  }

  .ps2p-copy :global(strong) {
    color: var(--ps2-ink);
    font-weight: 600;
  }

  .ps2p-side {
    display: flex;
    flex-direction: column;
    gap: 26px;
  }

  .ps2p-changelog {
    border: 1px solid var(--ps2-line);
    background: #fff;
    border-radius: 12px;
    padding: 22px 24px;
    font-family: var(--ps2-mono);
    font-size: 13.5px;
    line-height: 2;
  }

  .ps2p-changelog-title {
    color: var(--ps2-ink-soft);
    font-size: 12px;
    letter-spacing: 0.06em;
    margin-bottom: 8px;
  }

  .ps2p-cl-line {
    display: flex;
    gap: 10px;
  }

  .ps2p-cl-line .ps2p-cl-mark {
    width: 12px;
    flex: none;
  }

  .ps2p-cl-line--del {
    color: var(--ps2-broken);
  }

  .ps2p-cl-line--del s {
    color: var(--ps2-ink-soft);
    text-decoration-color: var(--ps2-broken);
    text-decoration-thickness: 1.5px;
  }

  .ps2p-cl-line--add {
    color: var(--ps2-cobalt);
    font-weight: 500;
  }

  .ps2p-live {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    align-self: flex-start;
    font-size: 15px;
    font-weight: 600;
    color: var(--ps2-ink);
    text-decoration: none;
    padding: 11px 20px;
    border: 1px solid var(--ps2-line);
    border-radius: 6px;
    background: transparent;
    transition: background 0.15s, border-color 0.15s, transform 0.15s;
  }

  .ps2p-live:hover {
    background: #fff;
    border-color: var(--ps2-ink);
    transform: translateY(-1px);
  }

  .ps2p-live span {
    transition: transform 0.15s;
  }

  .ps2p-live:hover span {
    transform: translateX(3px);
  }

  /* ---------- cta ---------- */
  .ps2p-cta {
    background: var(--ps2-cobalt);
    text-align: center;
    padding: 100px 0;
  }

  .ps2p-cta .ps2-eyebrow {
    color: #bcc8ff;
  }

  .ps2p-cta h2 {
    font-family: var(--ps2-disp);
    font-weight: 700;
    letter-spacing: -0.025em;
    font-size: clamp(30px, 3.6vw, 42px);
    line-height: 1.08;
    color: #fff;
    max-width: 18em;
    margin: 14px auto 0;
  }

  .ps2p-cta p {
    margin: 20px auto 36px;
    color: #d6ddff;
    max-width: 44ch;
  }

  .ps2p-cta-btn {
    display: inline-block;
    background: #fff;
    color: var(--ps2-cobalt);
    text-decoration: none;
    font-weight: 600;
    font-size: 16px;
    padding: 14px 30px;
    border-radius: 6px;
    transition: background 0.15s, transform 0.15s;
  }

  .ps2p-cta-btn:hover {
    background: var(--ps2-paper);
    transform: translateY(-1px);
  }

  .ps2p-cta-note {
    margin-top: 20px;
    font-family: var(--ps2-mono);
    font-size: 12.5px;
    color: #aabaff;
  }

  /* ---------- responsive ---------- */
  @media (max-width: 800px) {
    .ps2p-body {
      grid-template-columns: 1fr;
    }

    .ps2p-case-scope {
      margin-left: 0;
      flex-basis: 100%;
      order: 3;
    }

    .ps2p-ba-frame {
      aspect-ratio: 4 / 3;
    }
  }

  @media (max-width: 640px) {
    .ps2p-head {
      padding: 56px 0 44px;
    }

    .ps2p-case {
      padding: 60px 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ps2p-live,
    .ps2p-live span,
    .ps2p-cta-btn {
      transition: none;
    }
  }
</style>

<script>
  document.querySelectorAll('.ps2p [data-ba]').forEach((ba) => {
    const range = ba.querySelector('.ps2p-ba-range');
    const frame = ba.querySelector('.ps2p-ba-frame');
    if (!range || !frame) return;

    const setWidth = () => frame.style.setProperty('--fw', frame.clientWidth + 'px');

    const setPos = (v, animate) => {
      if (animate) {
        frame.style.setProperty('--pos-transition', 'all ' + animate);
      } else {
        frame.style.removeProperty('--pos-transition');
      }
      frame.style.setProperty('--pos', v + '%');
      range.value = v;
    };

    setWidth();
    setPos(50);
    window.addEventListener('resize', setWidth);

    range.addEventListener('input', () => {
      frame.style.removeProperty('--pos-transition');
      frame.style.setProperty('--pos', range.value + '%');
    });

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduce) {
      let played = false;
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting && !played) {
              played = true;
              setTimeout(() => {
                setPos(28, '1.0s cubic-bezier(0.4, 0, 0.2, 1)');
                setTimeout(() => setPos(50, '1.2s cubic-bezier(0.4, 0, 0.2, 1)'), 1100);
              }, 500);
            }
          });
        },
        { threshold: 0.5 }
      );
      io.observe(ba);
    }
  });
</script>
