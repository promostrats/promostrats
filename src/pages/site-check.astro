---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Free Site Check — PromoStrats"
  description="Enter your website URL and get an instant, free audit of its SEO, structure and usability basics — scored, with clear fixes. No email required."
>
  <div class="ps2sc">
    <!-- header + input -->
    <section class="ps2sc-top">
      <div class="ps2-wrap">
        <span class="ps2-eyebrow">// free site check</span>
        <h1>Is your website <span class="ps2sc-hl">working properly</span>?</h1>
        <p class="ps2sc-lede">
          Enter your URL and this tool will run a live check of the SEO, structure and usability basics search engines and
          customers care about - with separate SEO and design scores and plain-English fixes. Free, no email needed.
        </p>

        <form class="ps2sc-form" id="ps2sc-form" novalidate>
          <div class="ps2sc-input">
            <span class="ps2sc-input-prefix">https://</span>
            <input
              id="ps2sc-url"
              name="url"
              type="text"
              inputmode="url"
              autocomplete="url"
              placeholder="yourbusiness.com"
              aria-label="Your website address"
            />
          </div>
          <button type="submit" class="ps2-btn" id="ps2sc-run">Run the check</button>
        </form>
        <p class="ps2sc-note" id="ps2sc-note">takes ~10 seconds · SEO + design · nothing is stored</p>
      </div>
    </section>

    <!-- results panel -->
    <section class="ps2-wrap">
      <div class="ps2sc-panel" id="ps2sc-panel" hidden>
        <div class="ps2sc-panel-head">
          <span id="ps2sc-target">site-check.log</span>
          <span class="ps2sc-run-state" id="ps2sc-state">running&hellip;</span>
        </div>

        <div class="ps2sc-panel-body">
          <!-- error -->
          <div class="ps2sc-error" id="ps2sc-error" hidden></div>

          <!-- two score cards -->
          <div class="ps2sc-scores" id="ps2sc-scores" hidden>
            <div class="ps2sc-scorecard">
              <div class="ps2sc-score-ring" id="ps2sc-ring-seo">
                <span class="ps2sc-score-num" id="ps2sc-score-seo">0</span>
                <span class="ps2sc-score-max">/100</span>
              </div>
              <div class="ps2sc-scorecard-meta">
                <div class="ps2sc-scorecard-top">
                  <span class="ps2sc-scorecard-title">SEO</span>
                  <span class="ps2sc-grade" id="ps2sc-grade-seo">—</span>
                </div>
                <span class="ps2sc-scorecard-sub" id="ps2sc-sub-seo"></span>
              </div>
            </div>
            <div class="ps2sc-scorecard">
              <div class="ps2sc-score-ring" id="ps2sc-ring-design">
                <span class="ps2sc-score-num" id="ps2sc-score-design">0</span>
                <span class="ps2sc-score-max">/100</span>
              </div>
              <div class="ps2sc-scorecard-meta">
                <div class="ps2sc-scorecard-top">
                  <span class="ps2sc-scorecard-title">Design &amp; UX</span>
                  <span class="ps2sc-grade" id="ps2sc-grade-design">—</span>
                </div>
                <span class="ps2sc-scorecard-sub" id="ps2sc-sub-design"></span>
              </div>
            </div>
          </div>

          <!-- findings groups -->
          <div class="ps2sc-groups" id="ps2sc-groups"></div>

          <!-- cta -->
          <div class="ps2sc-cta" id="ps2sc-cta" hidden>
            <p>Want these fixed properly — or a site built right from the start?</p>
            <a class="ps2-btn" href="/contact">Book a free strategy call &rarr;</a>
            <a class="ps2sc-again" href="#" id="ps2sc-again">check another site</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .ps2sc-top {
    padding: 72px 0 40px;
  }

  .ps2sc-top h1 {
    font-family: var(--ps2-disp);
    font-weight: 800;
    font-size: clamp(34px, 4.8vw, 56px);
    line-height: 1.03;
    letter-spacing: -0.03em;
    margin-top: 20px;
    color: var(--ps2-ink);
  }

  .ps2sc-hl {
    color: var(--ps2-cobalt);
  }

  .ps2sc-lede {
    margin: 22px 0 32px;
    font-size: 18px;
    color: var(--ps2-ink-soft);
    max-width: 56ch;
  }

  /* input row */
  .ps2sc-form {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: stretch;
    max-width: 620px;
  }

  .ps2sc-input {
    display: flex;
    align-items: center;
    flex: 1 1 320px;
    background: #fff;
    border: 1px solid var(--ps2-line);
    border-radius: 8px;
    padding: 0 4px 0 14px;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .ps2sc-input:focus-within {
    border-color: var(--ps2-cobalt);
    box-shadow: 0 0 0 3px rgba(29, 59, 224, 0.12);
  }

  .ps2sc-input-prefix {
    font-family: var(--ps2-mono);
    font-size: 14px;
    color: #a6abb4;
    user-select: none;
  }

  .ps2sc-input input {
    flex: 1;
    border: 0;
    outline: 0;
    background: transparent;
    font-family: var(--ps2-mono);
    font-size: 15px;
    color: var(--ps2-ink);
    padding: 14px 10px;
    min-width: 0;
  }

  .ps2sc-input input::placeholder {
    color: #a6abb4;
  }

  #ps2sc-run {
    border: 0;
    cursor: pointer;
    font-size: 15px;
    padding: 0 26px;
    white-space: nowrap;
  }

  #ps2sc-run:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .ps2sc-note {
    margin-top: 16px;
    font-family: var(--ps2-mono);
    font-size: 12.5px;
    color: var(--ps2-ink-soft);
  }

  /* results panel */
  .ps2sc-panel {
    margin: 8px 0 96px;
    background: var(--ps2-panel);
    border: 1px solid var(--ps2-panel-line);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 24px 60px -24px rgba(21, 23, 27, 0.45);
  }

  .ps2sc-panel-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 18px;
    border-bottom: 1px solid var(--ps2-panel-line);
    font-family: var(--ps2-mono);
    font-size: 12.5px;
    color: #7a8291;
  }

  .ps2sc-run-state {
    color: var(--ps2-green);
  }

  .ps2sc-panel-body {
    padding: 26px 22px 28px;
  }

  .ps2sc-error {
    font-family: var(--ps2-mono);
    font-size: 14px;
    line-height: 1.6;
    color: #ffb4a2;
    background: rgba(192, 68, 43, 0.12);
    border: 1px solid rgba(192, 68, 43, 0.35);
    border-radius: 8px;
    padding: 16px 18px;
  }

  /* score ring (shared by both cards) */
  .ps2sc-score-ring {
    width: 108px;
    height: 108px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2px;
    background: var(--ps2-panel);
    border: 3px solid var(--ps2-green);
    transition: border-color 0.4s;
  }

  .ps2sc-score-num {
    font-family: var(--ps2-disp);
    font-weight: 800;
    font-size: 40px;
    color: #fff;
    line-height: 1;
  }

  .ps2sc-score-max {
    font-family: var(--ps2-mono);
    font-size: 13px;
    color: #7a8291;
  }

  .ps2sc-grade {
    font-family: var(--ps2-disp);
    font-weight: 800;
    font-size: 44px;
    letter-spacing: -0.02em;
    color: var(--ps2-green);
  }

  /* score cards */
  .ps2sc-scores {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    padding-bottom: 24px;
    margin-bottom: 4px;
    border-bottom: 1px dashed var(--ps2-panel-line);
  }

  .ps2sc-scorecard {
    display: flex;
    align-items: center;
    gap: 18px;
    border: 1px solid var(--ps2-panel-line);
    border-radius: 10px;
    padding: 18px 20px;
  }

  .ps2sc-scorecard .ps2sc-score-ring {
    width: 90px;
    height: 90px;
    flex: none;
  }

  .ps2sc-scorecard .ps2sc-score-num {
    font-size: 34px;
  }

  .ps2sc-scorecard-meta {
    display: flex;
    flex-direction: column;
    gap: 7px;
    min-width: 0;
  }

  .ps2sc-scorecard-top {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .ps2sc-scorecard-title {
    font-family: var(--ps2-disp);
    font-weight: 700;
    font-size: 20px;
    letter-spacing: -0.01em;
    color: #fff;
  }

  .ps2sc-scorecard-top .ps2sc-grade {
    font-size: 28px;
  }

  .ps2sc-scorecard-sub {
    font-family: var(--ps2-mono);
    font-size: 12px;
    color: #9aa1ad;
    line-height: 1.5;
  }

  @media (max-width: 560px) {
    .ps2sc-scores {
      grid-template-columns: 1fr;
    }
  }

  /* cta */
  .ps2sc-cta {
    margin-top: 26px;
    padding-top: 24px;
    border-top: 1px dashed var(--ps2-panel-line);
    text-align: center;
  }

  .ps2sc-cta p {
    color: #e8eaef;
    font-size: 16px;
    margin-bottom: 18px;
  }

  .ps2sc-again {
    display: block;
    margin-top: 16px;
    font-family: var(--ps2-mono);
    font-size: 12.5px;
    color: #7a8291;
    text-decoration: none;
  }

  .ps2sc-again:hover {
    color: var(--ps2-cobalt-light);
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .ps2sc-top {
      padding: 48px 0 32px;
    }

    #ps2sc-run {
      flex: 1;
      padding: 14px 26px;
    }
  }

</style>

<!-- Findings rows are injected by the script at runtime, so Astro can't scope
     their styles — they live here as global rules instead. -->
<style is:global>
  .ps2sc-groups {
    display: flex;
    flex-direction: column;
    gap: 26px;
    margin-top: 22px;
  }

  .ps2sc-group-head {
    font-family: var(--ps2-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--ps2-cobalt-light);
    margin-bottom: 6px;
  }

  .ps2sc-lines {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-family: var(--ps2-mono);
    font-size: 13.5px;
    line-height: 1.5;
  }

  .ps2sc-line {
    display: grid;
    grid-template-columns: 18px 1fr;
    gap: 12px;
    padding: 11px 4px;
    border-bottom: 1px solid rgba(38, 42, 50, 0.6);
    font-family: var(--ps2-mono);
    font-size: 13.5px;
    line-height: 1.5;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.25s, transform 0.25s;
  }

  .ps2sc-line.ps2sc-show {
    opacity: 1;
    transform: none;
  }

  .ps2sc-mark {
    text-align: center;
    font-weight: 700;
  }

  .ps2sc-line--pass .ps2sc-mark {
    color: var(--ps2-green);
  }

  .ps2sc-line--warn .ps2sc-mark {
    color: #f4c86a;
  }

  .ps2sc-line--fail .ps2sc-mark {
    color: #ff9c86;
  }

  .ps2sc-line-label {
    color: #e8eaef;
    font-weight: 500;
  }

  .ps2sc-line-detail {
    color: #9aa1ad;
    margin-top: 2px;
  }

  .ps2sc-line-advice {
    color: var(--ps2-cobalt-light);
    margin-top: 4px;
  }

  .ps2sc-line-advice::before {
    content: '\2192 ';
  }

  @media (prefers-reduced-motion: reduce) {
    .ps2sc-line {
      transition: none;
    }
  }
</style>

<script>
  const form = document.getElementById('ps2sc-form');
  const input = document.getElementById('ps2sc-url');
  const runBtn = document.getElementById('ps2sc-run');
  const panel = document.getElementById('ps2sc-panel');
  const state = document.getElementById('ps2sc-state');
  const target = document.getElementById('ps2sc-target');
  const errorBox = document.getElementById('ps2sc-error');
  const scores = document.getElementById('ps2sc-scores');
  const groupsBox = document.getElementById('ps2sc-groups');
  const ctaBox = document.getElementById('ps2sc-cta');
  const again = document.getElementById('ps2sc-again');

  const MARK = { pass: '✓', warn: '!', fail: '✗' };
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const esc = (s) =>
    String(s == null ? '' : s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));

  function reset() {
    errorBox.hidden = true;
    errorBox.textContent = '';
    scores.hidden = true;
    ctaBox.hidden = true;
    groupsBox.innerHTML = '';
  }

  function showError(msg) {
    reset();
    panel.hidden = false;
    state.textContent = 'error';
    state.style.color = '#ff9c86';
    errorBox.hidden = false;
    errorBox.textContent = msg;
  }

  function gradeColour(score) {
    if (score >= 75) return 'var(--ps2-green)';
    if (score >= 50) return '#f4c86a';
    return '#ff9c86';
  }

  function animateScore(el, targetScore) {
    if (reduced) {
      el.textContent = targetScore;
      return;
    }
    let cur = 0;
    const step = Math.max(1, Math.ceil(targetScore / 24));
    const tick = () => {
      cur += step;
      if (cur >= targetScore) cur = targetScore;
      el.textContent = cur;
      if (cur < targetScore) requestAnimationFrame(tick);
    };
    tick();
  }

  function setScorecard(group, rep) {
    const col = gradeColour(rep.score);
    document.getElementById('ps2sc-ring-' + group).style.borderColor = col;
    const g = document.getElementById('ps2sc-grade-' + group);
    g.textContent = rep.grade;
    g.style.color = col;
    document.getElementById('ps2sc-sub-' + group).textContent =
      `${rep.counts.pass} good · ${rep.counts.warn} to improve · ${rep.counts.fail} issue${rep.counts.fail === 1 ? '' : 's'}`;
    animateScore(document.getElementById('ps2sc-score-' + group), rep.score);
  }

  function renderLineInto(container, f, i) {
    const el = document.createElement('div');
    el.className = 'ps2sc-line ps2sc-line--' + f.status;
    el.innerHTML =
      `<span class="ps2sc-mark">${MARK[f.status]}</span>` +
      `<span><span class="ps2sc-line-label">${esc(f.label)}</span>` +
      `<div class="ps2sc-line-detail">${esc(f.detail)}</div>` +
      (f.advice ? `<div class="ps2sc-line-advice">${esc(f.advice)}</div>` : '') +
      `</span>`;
    container.appendChild(el);
    const delay = reduced ? 0 : 80 * i;
    setTimeout(() => el.classList.add('ps2sc-show'), delay + 20);
  }

  function renderGroup(title, rep, startIndex) {
    const sec = document.createElement('div');
    sec.className = 'ps2sc-group';
    const head = document.createElement('div');
    head.className = 'ps2sc-group-head';
    head.textContent = `// ${title} — ${rep.findings.length} checks`;
    sec.appendChild(head);
    const lines = document.createElement('div');
    lines.className = 'ps2sc-lines';
    sec.appendChild(lines);
    groupsBox.appendChild(sec);
    let i = startIndex;
    rep.findings.forEach((f) => renderLineInto(lines, f, i++));
    return i;
  }

  function renderReport(data) {
    reset();
    panel.hidden = false;
    let host = data.finalUrl || data.url || '';
    try { host = new URL(host).host; } catch {}
    target.textContent = host + ' — site-check.log';

    setScorecard('seo', data.seo);
    setScorecard('design', data.design);
    scores.hidden = false;

    let idx = 0;
    idx = renderGroup('SEO', data.seo, idx);
    idx = renderGroup('Design & UX', data.design, idx);

    state.textContent = 'done ✓';
    state.style.color = 'var(--ps2-green)';
    const lastDelay = reduced ? 0 : 80 * idx;
    setTimeout(() => {
      ctaBox.hidden = false;
    }, lastDelay + 300);
  }

  async function run(url) {
    reset();
    panel.hidden = false;
    target.textContent = 'site-check.log';
    state.textContent = 'running…';
    state.style.color = 'var(--ps2-green)';
    runBtn.disabled = true;
    runBtn.textContent = 'Checking…';

    try {
      const res = await fetch('/api/audit?url=' + encodeURIComponent(url), {
        headers: { Accept: 'application/json' },
      });
      const ct = res.headers.get('content-type') || '';
      if (!ct.includes('application/json')) {
        // Most likely running under `astro dev`, where /api functions don't run.
        showError(
          'The live audit runs on the deployed site. Push your changes and try it on your live URL (or run `vercel dev` locally).'
        );
        return;
      }
      const data = await res.json();
      if (data.error) {
        showError(data.error);
        return;
      }
      renderReport(data);
    } catch {
      showError('Something went wrong running the check. Please try again in a moment.');
    } finally {
      runBtn.disabled = false;
      runBtn.textContent = 'Run the check';
    }
  }

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const val = (input.value || '').trim();
    if (!val) {
      input.focus();
      return;
    }
    run(val);
    panel.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth', block: 'start' });
  });

  again?.addEventListener('click', (e) => {
    e.preventDefault();
    panel.hidden = true;
    input.focus();
    input.select();
    window.scrollTo({ top: 0, behavior: reduced ? 'auto' : 'smooth' });
  });

  // Allow deep-linking: /site-check?url=example.com auto-runs
  const preset = new URLSearchParams(window.location.search).get('url');
  if (preset) {
    input.value = preset;
    run(preset);
  }
</script>
